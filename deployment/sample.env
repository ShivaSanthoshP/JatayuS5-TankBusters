# ── LLM provider ────────────────────────────────────────────────────
# Which provider the agents use. Switch anytime via the Settings UI.
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# OpenAI (optional — leave blank if not using)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Ollama (local — not recommended on small EC2 instances)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ── CORS ─────────────────────────────────────────────────────────────
# Set to your EC2 public IP or domain name (no trailing slash).
# Both frontend and backend are on the same origin in prod (nginx proxy),
# so CORS is only needed if you access the API directly from another origin.
CORS_ALLOW_ORIGINS=http://YOUR_EC2_PUBLIC_IP

# ── Database ─────────────────────────────────────────────────────────
# Production (EC2): leave commented — setup-ec2.sh writes DATABASE_URL into
# /etc/itops-db.env and the systemd unit loads it from there.
# Local dev: pick one of the lines below.
# DATABASE_URL=sqlite:///./itops.db
# DATABASE_URL=postgresql://itops:CHANGEME@localhost:5432/itops

# ── ChromaDB vector store ────────────────────────────────────────────
# Local EBS (default — used if S3 Files mount is not set up):
# CHROMA_PERSIST_DIR=/opt/itops/backend/chroma_db
# S3 Files mount (production — set after running cloud-shell-bootstrap.sh):
CHROMA_PERSIST_DIR=/mnt/s3/itops/chroma_db

# ── Simulator ────────────────────────────────────────────────────────
SIMULATOR_INTERVAL_SECONDS=10
NUM_SIMULATED_SERVERS=6
ANOMALY_PROBABILITY=0.15
AGENT_TEMPERATURE=0.1

# ── Pipeline ─────────────────────────────────────────────────────────
# Limit concurrent LLM pipeline runs to protect the event loop.
PIPELINE_MAX_CONCURRENT=4
